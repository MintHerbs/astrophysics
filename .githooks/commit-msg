#!/bin/sh
# commit-msg hook: strip AI tool-attribution lines so every commit reads as
# authored solely by the repository owner.
#
# Removes:
#   - "Co-Authored-By:" trailer lines (any casing, leading whitespace allowed)
#   - a "Generated with ... Claude Code" footer line (any casing)
# then collapses any trailing blank lines left behind.
#
# This is a backstop. The primary rule is to not write these lines at all
# (see CLAUDE.md and .claude/settings.json includeCoAuthoredBy=false).
#
# Enable once per clone with:  git config core.hooksPath .githooks

msg_file="$1"
[ -f "$msg_file" ] || exit 0

tmp="${msg_file}.stripped"

grep -viE '^[[:space:]]*co-authored-by:' "$msg_file" \
  | grep -viE 'generated with .*claude code' > "$tmp" 2>/dev/null

# If filtering produced no file (edge case), keep the original untouched.
[ -f "$tmp" ] || exit 0

# Strip trailing blank lines while preserving blank lines inside the message.
awk '{ lines[NR] = $0 }
     END {
       last = NR
       while (last > 0 && lines[last] ~ /^[[:space:]]*$/) last--
       for (i = 1; i <= last; i++) print lines[i]
     }' "$tmp" > "$msg_file"

rm -f "$tmp"
exit 0
