# ============================================================
# Research data artefacts. Raw spectra and large archive
# products are NEVER committed. Only derived, lightweight
# catalogues and code live in this repository.
# See docs/04-data-sources.md and .claude/rules/data.md
# ============================================================

# Raw and downloaded archive products (MAST, NASA Exoplanet Archive)
data/raw/
data/downloads/
data/mast/
data/cache/

# Bulk spectra in common astronomy and array formats
*.fits
*.fits.gz
*.h5
*.hdf5
*.npy
*.npz

# Generated synthetic training sets and model checkpoints
data/synthetic/
data/training/
models/
checkpoints/
*.pt
*.pth
*.ckpt
*.pkl
*.joblib

# Opacity tables and cross-section databases (large, fetched separately)
data/opacities/
opacity_data/

# Inference outputs and figures (regenerable)
outputs/
results/runs/
figures/

# Large derived catalogues (keep only the curated, small ones under version control by
# explicitly force-adding them, for example: git add -f data/catalogues/dataset_catalogue.csv)
data/catalogues/*.csv
