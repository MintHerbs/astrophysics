{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf --no-preserve-root*)",
      "Bash(sudo rm -rf *)",
      "Bash(mkfs*)",
      "Bash(dd *)",
      "Bash(shred *)",
      "Bash(> /dev/sd*)",
      "PowerShell(Format-Volume*)",
      "PowerShell(Clear-Disk*)",
      "PowerShell(Initialize-Disk*)",
      "PowerShell(Remove-Partition*)",
      "PowerShell(Remove-Item -Recurse -Force C:\\*)",
      "PowerShell(Remove-Item -Recurse -Force /*)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(rm -f *)",
      "Bash(rmdir *)",
      "Bash(git reset --hard*)",
      "Bash(git clean*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git checkout -- *)",
      "Bash(git restore*)",
      "Bash(git branch -D*)",
      "Bash(chmod -R*)",
      "Bash(truncate *)",
      "PowerShell(Remove-Item -Recurse*)",
      "PowerShell(Remove-Item -Force*)",
      "PowerShell(Remove-Item -r*)",
      "PowerShell(ri -Recurse*)",
      "PowerShell(rm -r*)",
      "PowerShell(rmdir *)",
      "PowerShell(rd *)",
      "PowerShell(del *)",
      "PowerShell(Clear-Content*)",
      "PowerShell(git reset --hard*)",
      "PowerShell(git clean*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "PowerShell(git checkout -- *)",
      "PowerShell(git branch -D*)"
    ],
    "allow": [
      "mcp__codegraph__*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "codegraph prompt-hook"
          }
        ]
      }
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/protect_frozen_docs.py\""
          }
        ]
      }
    ]
  }
}
